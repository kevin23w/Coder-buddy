# Coder Buddy — environment variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Core optional ─────────────────────────────────────────────────────────────
MAX_RETRIES=3
LOG_LEVEL=INFO
TEST_TIMEOUT=60
RATE_LIMIT=10/minute
# Comma-separated paths the agent is allowed to read/fix. Empty = allow all.
ALLOWED_REPO_PATHS=

# ── GitHub PR integration ─────────────────────────────────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (full)
GITHUB_TOKEN=your_github_pat_here
# Full repo name, e.g. "myusername/my-project"
GITHUB_REPO=username/repository
# Branch to merge the PR into (default: main)
GITHUB_BASE_BRANCH=main

# ── Slack notifications ───────────────────────────────────────────────────────
# Create an Incoming Webhook at: https://api.slack.com/apps → Incoming Webhooks
# Leave empty to disable
SLACK_WEBHOOK_URL=

# ── Discord notifications ─────────────────────────────────────────────────────
# Create a Webhook in Discord: Server Settings → Integrations → Webhooks
# Leave empty to disable
DISCORD_WEBHOOK_URL=
