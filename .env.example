# ── Coder Buddy SaaS — Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values.

# ── Groq (required) ───────────────────────────────────────────────────────────
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Core settings ─────────────────────────────────────────────────────────────
MAX_RETRIES=3
LOG_LEVEL=INFO
ALLOWED_REPO_PATHS=
TEST_TIMEOUT=60
RATE_LIMIT=10/minute

# ── Supabase (required for auth + DB) ─────────────────────────────────────────
# Create free project at: https://supabase.com → New Project
# Then: Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Razorpay (required for payments) ──────────────────────────────────────────
# Create free account at: https://razorpay.com → Sign Up
# Then: Account Settings → API Keys → Generate Key
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX
# Dashboard → Webhooks → Add webhook → copy secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Resend (required for emails) ──────────────────────────────────────────────
# Free account at: https://resend.com → 3,000 emails/month free
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── GitHub PR integration (optional) ──────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# ── Slack/Discord notifications (optional) ────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── App URLs ───────────────────────────────────────────────────────────────────
# Your Vercel landing page URL
NEXT_PUBLIC_APP_URL=https://coder-buddy.vercel.app

# ── Landing page (Next.js — set in Vercel env vars) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=https://coder-buddy-api.onrender.com
